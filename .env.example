# cogent 环境变量示例：复制为 .env 并填入真实值（.env 已被 .gitignore 排除）

# ---- LLM 接入（Phase 1 起生效）----
# DeepSeek API 密钥，仅从环境变量读取，严禁硬编码
DEEPSEEK_API_KEY=
# LLM OpenAI 兼容接口 BaseURL
COGENT_LLM_BASE_URL=https://api.deepseek.com/v1

# ---- 可观测（Phase 8 起生效，Phase 0 仅 no-op）----
# 总开关
COGENT_OBSERVE_ENABLED=false
# trace exporter：file | otlp | none
COGENT_TRACE_EXPORTER=file
# file exporter 输出目录
COGENT_TRACE_DIR=./data/traces
# exporter=otlp 时的地址
COGENT_OTLP_ENDPOINT=localhost:4317
# 采样率 0.0~1.0
COGENT_TRACE_SAMPLE_RATIO=1.0

# ---- 日志 ----
# 日志级别：debug | info | warn | error
COGENT_LOG_LEVEL=info
