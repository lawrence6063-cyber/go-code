# 运行期数据（会话 transcript 与 trace span）
/data/

# 评测跑分归档（报告 + 工作区副本 + trace，体积大且可重生成，不入库）
/eval-artifacts/

# 环境变量与密钥（仅从 env 读取，严禁入库）
.env
.env.local

# 编译产物
/cogent
*.exe
*.test
*.out

# 覆盖率
coverage.txt
*.cover

# 依赖目录（不提交 vendor）
/vendor/

# 编辑器 / 操作系统
.DS_Store
.idea/
.vscode/
*.swp
bin/

# Python 编译缓存
__pycache__/
*.pyc
